{
  "$ref": "#/definitions/posts",
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "abstract": {
          "type": "string"
        },
        "imagen": {
          "type": "string"
        },
        "ogImage": {
          "type": "string"
        },
        "topic": {
          "type": "string",
          "enum": [
            "arte",
            "disney",
            "viajes"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "fecha": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "seoTitle": {
          "type": "string",
          "maxLength": 70
        },
        "seoDescription": {
          "type": "string",
          "maxLength": 180
        },
        "canonical": {
          "type": "string",
          "format": "uri"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "abstract",
        "imagen",
        "topic",
        "fecha"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}