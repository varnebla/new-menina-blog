---
import ListLayout from '../../layouts/ListLayout.astro';
import BlogPostListItem from '../../components/BlogPostListItem.astro';
import BlogPostEmpty from '../../components/BlogPostEmpty.astro';
import { getPostsByTopic } from '../../services/posts';
import { toAbsoluteUrl } from '../../utils/seo';
import { TOPIC_DEFINITIONS, getTopicDefinition } from '../../utils/topics';

export async function getStaticPaths() {
  return TOPIC_DEFINITIONS.map((topic) => ({
    params: { topic: topic.slug },
  }));
}

const { topic } = Astro.params;
const currentTopic = getTopicDefinition(topic || 'arte');
const filteredPosts = await getPostsByTopic(currentTopic.slug);
const topicDescription = currentTopic.description;
const seoDescription = currentTopic.seoDescription || topicDescription;
const breadcrumbs = [
  { name: 'Inicio', url: toAbsoluteUrl('/') },
  { name: 'Posts', url: toAbsoluteUrl('/posts') },
  { name: currentTopic.label, url: toAbsoluteUrl(Astro.url.pathname) },
];
---

<ListLayout
  title={`Archivo de ${currentTopic.label}`}
  topic={currentTopic.slug}
  eyebrow={currentTopic.kicker}
  pageDescription={seoDescription}
  breadcrumbs={breadcrumbs}
>
  <section
    id={`${currentTopic.slug}-posts`}
    class="grid grid-cols-1 sm:grid-cols-2 gap-y-12 gap-x-8 pt-4"
  >
    {
      !filteredPosts || !filteredPosts.length ? (
        <BlogPostEmpty />
      ) : (
        filteredPosts.map((post, index) => {
          const isEagerImg = index < 2;
          return <BlogPostListItem post={post} isEagerImg={isEagerImg} />;
        })
      )
    }
  </section>
</ListLayout>
