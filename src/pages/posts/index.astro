---
import ListLayout from '../../layouts/ListLayout.astro';
import BlogPostListItem from '../../components/BlogPostListItem.astro';

import { getPostsOrderedByDate } from '../../services/posts';

const posts = await getPostsOrderedByDate();
---

<ListLayout
  title="Todos los posts"
  topic="all"
  eyebrow="Archivo completo"
  pageDescription="Explora todos los artículos sobre arte, viajes y curiosidades culturales. Un archivo ordenado para descubrir obras, referencias visuales y rutas con más contexto."
>
  <section
    id="all-posts"
    class="grid grid-cols-1 sm:grid-cols-2 gap-y-12 gap-x-8 pt-4"
  >
    {
      posts.map((post, index) => {
        const isEagerImg = index < 2;
        return <BlogPostListItem post={post} isEagerImg={isEagerImg} />;
      })
    }
  </section>
</ListLayout>
