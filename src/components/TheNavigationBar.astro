---
import { TOPIC_DEFINITIONS } from '../utils/topics';

const navigationLinks = [
  { href: '/posts', label: 'Archivo' },
  ...TOPIC_DEFINITIONS.map((topic) => ({
    href: `/topic/${topic.slug}`,
    label: topic.label,
  })),
];
---

<header
  id="navigationBar"
  class="fixed top-0 left-0 right-0 z-20 text-pearl-900 navigation-bar border-b border-pearl-200/70 bg-background/85"
  transition:persist
>
  <div
    class="px-4 lg:px-0 max-w-6xl mx-auto w-full flex items-center justify-between gap-x-6"
  >
    <a
      id="navigationBarTitle"
      href="/"
      title="Ir a la página principal"
      class="py-5 flex flex-col transition-opacity duration-200"
    >
      <span class="text-lg font-semibold tracking-tight">La menina perdida</span
      >
      <span class="text-[11px] uppercase tracking-[0.28em] text-pearl-700">
        Blog cultural
      </span>
    </a>
    <nav class="text-[15px] gap-x-2 hidden lg:flex relative items-center">
      {
        navigationLinks.map((link) => (
          <a
            href={link.href}
            class="hover:bg-white/80 px-4 py-2 rounded-full flex items-center gap-x-1 transition-colors duration-150"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <button
      id="open-mobile-navigation-btn"
      class="inline lg:hidden hamburguer rounded-full border border-pearl-200 bg-white/80 p-2"
      aria-label="Abrir menú de navegación"
      aria-controls="mobile-navigation"
      aria-expanded="false"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="4" y1="12" x2="20" y2="12"></line><line
          x1="4"
          y1="6"
          x2="20"
          y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
    <button
      id="close-mobile-navigation-btn"
      style="display: none;"
      class="lg:hidden absolute right-0 top-0 mx-4 my-5 rounded-full border border-pearl-200 bg-white/90 p-2"
      aria-label="Cerrar menú de navegación"
      aria-controls="mobile-navigation"
      aria-expanded="true"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
  <div
    id="mobile-navigation"
    class="px-4 pt-2 pb-5 w-full animate-fade-in-down border-t border-pearl-200/80 bg-background/95"
    style="display:none"
  >
    <nav class="max-w-6xl mx-auto flex flex-col gap-y-4 text-lg font-medium">
      {
        navigationLinks.map((link) => (
          <a href={link.href} class="py-1">
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const mobileNavigation = document.querySelector(
    '#mobile-navigation',
  ) as HTMLElement;
  const closeButton = document.querySelector(
    '#close-mobile-navigation-btn',
  ) as HTMLElement;
  const openSideMenuButton = document.querySelector(
    '#open-mobile-navigation-btn',
  ) as HTMLElement;

  const closeMenu = () => {
    closeButton.style.display = 'none';
    openSideMenuButton.style.removeProperty('display');
    openSideMenuButton.setAttribute('aria-expanded', 'false');
    closeButton.setAttribute('aria-expanded', 'false');
    mobileNavigation.style.display = 'none';
  };

  const openMenu = () => {
    openSideMenuButton.style.display = 'none';
    closeButton.style.display = 'inline-block';
    openSideMenuButton.setAttribute('aria-expanded', 'true');
    closeButton.setAttribute('aria-expanded', 'true');
    mobileNavigation.style.display = 'block';
  };

  openSideMenuButton.addEventListener('click', openMenu);
  closeButton.addEventListener('click', closeMenu);

  document.addEventListener('astro:before-swap', closeMenu);

  const desktopMediaQuery = window.matchMedia('(min-width: 1024px)');

  desktopMediaQuery.addEventListener('change', (event) => {
    if (event.matches) {
      closeMenu();
    }
  });
</script>
<style>
  .navigation-bar {
    animation: navigation-bar-scroll both linear;
    animation-timeline: scroll();
    animation-range: normal 100px;
  }
  @keyframes navigation-bar-scroll {
    /* from {
      backdrop-filter: blur(0px);
      box-shadow: none;
    } */
    to {
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 40px rgba(51, 51, 51, 0.08);
    }
  }
</style>
