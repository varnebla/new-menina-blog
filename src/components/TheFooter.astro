---
import { TOPIC_DEFINITIONS } from '../utils/topics';
---

<footer
  class="px-4 lg:px-0 py-10 w-full max-w-6xl mx-auto mt-auto text-pearl-700 border-t border-pearl-200 text-sm"
>
  <div
    class="grid gap-10 lg:grid-cols-[minmax(0,1.5fr)_repeat(2,minmax(0,1fr))]"
  >
    <div class="space-y-4 max-w-md">
      <p class="text-[11px] uppercase tracking-[0.32em] text-gold-700">
        La menina perdida
      </p>
      <p
        class="font-serif text-2xl text-pearl-900 leading-tight tracking-tight"
      >
        Un blog para mirar el arte, los viajes y la cultura visual con otros
        ojos.
      </p>
      <p>
        Artículos, curiosidades y recorridos para acercar el patrimonio a un
        público amplio, sin perder rigor ni contexto.
      </p>
    </div>

    <div class="space-y-4">
      <p class="text-[11px] uppercase tracking-[0.28em] text-pearl-700">
        Explorar
      </p>
      <nav class="flex flex-col gap-y-2">
        <a href="/posts" class="hover:text-pearl-900">Todos los posts</a>
        {
          TOPIC_DEFINITIONS.map((topic) => (
            <a href={`/topic/${topic.slug}`} class="hover:text-pearl-900">
              {topic.label}
            </a>
          ))
        }
        <a href="/sobre" class="hover:text-pearl-900">Sobre mí</a>
        <a href="/rss.xml" class="hover:text-pearl-900">RSS</a>
      </nav>
    </div>

    <div class="space-y-4">
      <p class="text-[11px] uppercase tracking-[0.28em] text-pearl-700">
        Seguir
      </p>
      <div class="flex items-center justify-start gap-x-3">
        <a
          href="https://instagram.com/lameninaperdida"
          title="Ir al perfil Instagram de La menina perdida"
          class="hover:underline"
          target="_blank"
          rel="noreferrer noopener"
          ><svg
            class="w-6 h-6 text-pearl-700 hover:text-pearl-900"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              fill="currentColor"
              fill-rule="evenodd"
              d="M3 8a5 5 0 0 1 5-5h8a5 5 0 0 1 5 5v8a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5V8Zm5-3a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3V8a3 3 0 0 0-3-3H8Zm7.597 2.214a1 1 0 0 1 1-1h.01a1 1 0 1 1 0 2h-.01a1 1 0 0 1-1-1ZM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-5 3a5 5 0 1 1 10 0 5 5 0 0 1-10 0Z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
        <a
          href="https://twitter.com/lameninaperdida"
          title="Ir al perfil de X de La menina perdida"
          class="hover:underline"
          target="_blank"
          rel="noreferrer noopener"
          ><svg
            class="w-5 h-5 text-pearl-700 hover:text-pearl-900"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M13.795 10.533 20.68 2h-3.073l-5.255 6.517L7.69 2H1l7.806 10.91L1.47 22h3.074l5.705-7.07L15.31 22H22l-8.205-11.467Zm-2.38 2.95L9.97 11.464 4.36 3.627h2.31l4.528 6.317 1.443 2.02 6.018 8.409h-2.31l-4.934-6.89Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
