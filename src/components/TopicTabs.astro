---
import { TOPIC_DEFINITIONS } from '../utils/topics';

interface Props {
  activeTab: string;
}

const { activeTab } = Astro.props;

const tabs = [
  { slug: 'all', label: 'Todos los posts', href: '/posts' },
  ...TOPIC_DEFINITIONS.map((topic) => ({
    slug: topic.slug,
    label: topic.label,
    href: `/topic/${topic.slug}`,
  })),
];
---

<nav class="mb-4 border-b border-pearl-200" aria-label="Filtrar por tema">
  <ul class="flex flex-wrap -mb-px gap-x-1 text-sm font-medium text-center">
    {
      tabs.map((tab) => (
        <li>
          <a
            href={tab.href}
            aria-current={activeTab == tab.slug ? 'page' : undefined}
            class:list={[
              'inline-flex items-center rounded-t-full px-4 py-3 transition-colors duration-150',
              activeTab == tab.slug
                ? 'border-b-2 border-pearl-900 font-semibold text-pearl-900'
                : 'text-pearl-700 hover:text-pearl-900',
            ]}
          >
            {tab.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
