---
import TheNavigationBar from '../components/TheNavigationBar.astro';
import TheFooter from '../components/TheFooter.astro';
import { ClientRouter } from 'astro:transitions';
import {
  buildPageTitle,
  DEFAULT_OG_IMAGE,
  DEFAULT_SITE_DESCRIPTION,
  getCanonicalUrl,
  SITE_NAME,
  SITE_URL,
  toAbsoluteUrl,
} from '../utils/seo';

// Supports weights 400-700
import '@fontsource-variable/lora';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/700.css';

const {
  pageTitle,
  pageDescription,
  layout = 'BaseLayout',
  ogImage,
  ogTitle,
  ogDescription,
  canonical,
  structuredData,
  noIndex = false,
  contentWidth = 'default',
} = Astro.props;

const finalDescription = pageDescription || DEFAULT_SITE_DESCRIPTION;
const finalTitle = buildPageTitle(pageTitle);
const finalOgTitle = ogTitle || finalTitle;
const finalOgDescription = ogDescription || finalDescription;
const finalOgImage = toAbsoluteUrl(ogImage || DEFAULT_OG_IMAGE);
const canonicalUrl = getCanonicalUrl(Astro.url.pathname, canonical);
const robotsContent = noIndex
  ? 'noindex, nofollow'
  : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const widthClass =
  contentWidth === 'wide'
    ? 'max-w-6xl'
    : contentWidth === 'post'
      ? 'max-w-none'
      : 'max-w-4xl';
const openGraphType = layout === 'PostLayout' ? 'article' : 'website';
---

<html lang="es" class="min-h-screen">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image" href="/favicon-menina.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`RSS | ${SITE_NAME}`}
      href="/rss.xml"
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={finalDescription} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#F5F0E4" />

    <!-- Facebook Meta Tags -->
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={finalOgDescription} />
    <meta property="og:image" content={finalOgImage} />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="lameninaperdida.art" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={finalOgTitle} />
    <meta name="twitter:description" content={finalOgDescription} />
    <meta name="twitter:image" content={finalOgImage} />

    <title>{finalTitle}</title>
    <script
      defer
      src="https://analytics.varnebla.dev/script.js"
      data-website-id="4abe6b12-164b-4027-be04-68d4438434f5"></script>
    <script>
      if (!import.meta.env.PROD) localStorage.setItem('umami.disabled', '1');
    </script>
    {
      structuredDataItems.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <ClientRouter />
  </head>
  <body
    class="flex flex-col min-h-screen text-lg font-sans relative bg-background text-pearl-900 selection:bg-gold-200/60"
  >
    <TheNavigationBar />
    <div
      class="post-progress"
      class:list={[layout != 'PostLayout' && 'hidden']}
    >
    </div>
    <main class:list={['px-4 lg:px-0 mx-auto w-full mb-16 mt-24', widthClass]}>
      <slot />
    </main>
    <TheFooter />
  </body>
</html>

<style>
  html {
    scroll-timeline: --page-scroll block;
  }
  .post-progress {
    position: fixed;
    left: 0;
    top: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, #c9a66b, #8c5e00);
    z-index: 20;
    transform-origin: 0 50%;
    animation: grow-progress auto linear;
    animation-timeline: --page-scroll;
  }

  @keyframes grow-progress {
    0% {
      transform: scaleX(0);
    }
    100% {
      transform: scaleX(1);
    }
  }
</style>
