---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import BlogPostListItem from '../components/BlogPostListItem.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../utils/date';
import {
  buildBlogPostingSchema,
  buildBreadcrumbSchema,
  toAbsoluteUrl,
} from '../utils/seo';
import { normalizeTagSlug } from '../utils/taxonomy';
import { getTopicDefinition } from '../utils/topics';
import type { PostEntry } from '../services/posts';

interface Props {
  title: string;
  seoTitle?: string;
  date: Date;
  topic: string;
  imagen: string;
  pageDescription: string;
  slug: string;
  tags?: string[];
  relatedPosts?: PostEntry[];
  canonical?: string;
  ogImage?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const {
  title,
  seoTitle,
  date,
  topic,
  imagen,
  pageDescription,
  slug,
  tags = [],
  relatedPosts = [],
  canonical,
  ogImage,
  headings = [],
} = Astro.props;

const formatedDate = formatDate(date);
const topicDefinition = getTopicDefinition(topic);
const canonicalUrl = canonical
  ? toAbsoluteUrl(canonical)
  : toAbsoluteUrl(Astro.url.pathname);
const fullImageUrl = toAbsoluteUrl(ogImage || imagen);
const pageHeading = seoTitle || title;
const structuredData = [
  buildBlogPostingSchema({
    title: pageHeading,
    description: pageDescription,
    url: canonicalUrl,
    image: fullImageUrl,
    datePublished: new Date(date).toISOString(),
    keywords: tags,
    section: topicDefinition.label,
  }),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: toAbsoluteUrl('/') },
    { name: 'Posts', url: toAbsoluteUrl('/posts') },
    { name: title, url: canonicalUrl },
  ]),
];
---

<BaseLayout
  pageTitle={pageHeading}
  pageDescription={pageDescription}
  layout="PostLayout"
  ogTitle={pageHeading}
  ogDescription={pageDescription}
  ogImage={fullImageUrl}
  canonical={canonicalUrl}
  structuredData={structuredData}
  contentWidth="post"
>
  <div class="pt-6 mb-16">
    <!-- Post header: title, meta, image — narrow -->
    <div class="max-w-[65ch] mx-auto">
      <div class="flex flex-col gap-y-6 mb-10">
        <a
          href={`/topic/${topic}`}
          title={`Ir a los posts de ${topic}`}
          class="text-[11px] w-max uppercase tracking-[0.28em] text-gold-700 hover:underline"
          >{topicDefinition.label}</a
        >
        <h1
          class="font-serif text-4xl lg:text-6xl leading-[1.02] tracking-[-0.025em] text-pearl-900"
        >
          {title}
        </h1>
        <p class="text-base lg:text-lg text-pearl-700 leading-relaxed">
          {pageDescription}
        </p>
        <div
          class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-pearl-500"
        >
          <time>{formatedDate}</time>
          <span>•</span>
          {
            tags.map((tag) => (
              <a
                href={`/tags/${normalizeTagSlug(tag)}`}
                class="text-pearl-700 transition-colors duration-150 hover:text-pearl-900 hover:underline"
              >
                #{tag}
              </a>
            ))
          }
        </div>
        <Image
          src={imagen}
          alt={title}
          title={title}
          width={1200}
          height={720}
          class="aspect-[16/9] rounded-2xl object-cover"
          loading="eager"
        />
      </div>

      {
        headings.filter((h) => h.depth === 2 || h.depth === 3).length > 1 && (
          <details class="xl:hidden mb-8 group">
            <summary class="cursor-pointer py-2 text-sm text-pearl-700 select-none list-none flex items-center gap-2 hover:text-pearl-900 transition-colors duration-150">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-pearl-400 transition-transform duration-200 group-open:rotate-180"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
              Contenidos
            </summary>
            <div class="mt-3 rounded-xl bg-pearl-200 px-4 py-4">
              <TableOfContents headings={headings} />
            </div>
          </details>
        )
      }
    </div>

    <!--
      3-col grid at xl+: [spacer 1fr] [article 65ch] [toc 200px]
      The 1fr spacer mirrors the ToC column so the article stays centred.
      sticky works because the ToC is in normal document flow.
    -->
    <div
      class="xl:grid xl:grid-cols-[1fr_min(60ch,100%)_1fr] xl:gap-x-10 xl:items-start"
    >
      <div class="hidden xl:block" aria-hidden="true"></div>
      <article
        class="max-w-[65ch] mx-auto xl:max-w-none xl:mx-0 prose prose-pearl prose-lg lg:prose-xl font-serif prose-headings:scroll-mt-28 prose-img:max-w-lg prose-img:mx-auto prose-img:rounded prose-img:w-full [&_strong]:font-semibold [&_img+em]:text-center [&_img+em]:block [&_a]:underline"
      >
        <slot />
      </article>
      <aside
        class="hidden xl:flex xl:justify-start self-start sticky top-28 pl-4"
      >
        <div class="w-[180px]">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>

    <!-- Closing note -->
    <div
      class="max-w-[65ch] mx-auto mt-12 border-t border-pearl-200 pt-8 flex flex-col gap-y-2 sm:flex-row sm:items-center sm:justify-between text-sm text-pearl-700"
    >
      <p>¿Te ha gustado este artículo? Compártelo o sigue leyendo.</p>
      <div class="flex items-center gap-x-4">
        <a
          href="/posts"
          class="hover:text-pearl-900 hover:underline transition-colors duration-150"
          >Ver todos los posts</a
        >
        <a
          href="/sobre"
          class="hover:text-pearl-900 hover:underline transition-colors duration-150"
          >Sobre mí</a
        >
      </div>
    </div>

    {
      relatedPosts.length ? (
        <aside class="max-w-[65ch] mx-auto mt-16 border-t border-pearl-200 pt-10">
          <div class="flex flex-col gap-y-2 mb-8">
            <p class="text-[11px] uppercase tracking-[0.32em] text-gold-700">
              Seguir explorando
            </p>
            <h2 class="font-serif text-3xl lg:text-4xl leading-tight tracking-tight text-pearl-900">
              Más lecturas relacionadas
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {relatedPosts.map((post) => (
              <BlogPostListItem post={post} />
            ))}
          </div>
        </aside>
      ) : null
    }
  </div>
</BaseLayout>
